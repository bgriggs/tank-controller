{
  "CerboIP": "192.168.1.100",
  "SensorVRMInstance": 31, // VRM Instance under the sensor name->Device in the Cerbo site
  "AmbientTempSensorVRMInstance": 34, // Optionally used to ensure the air being pulled in is cooler than the threshold temp
  "TempCheckIntervalMs": 60000,
  "TempThresholdDegF": 34,
  "TempThresholdOffDegF": 33,
  "RelayGPIOPin": 26, // GPIO26 is pin 37 on RPi
  "HeatOnLed": 27,
  "SystemRunningLed": 28,

  "NLog": {
    "throwConfigExceptions": true,
    "targets": {
      "console": {
        "type": "ColoredConsole",
        "layout": "${longdate}|${pad:padding=5:inner=${level:uppercase=true}}|${logger}|${message}${onexception:inner=|${exception:format=tostring}${newline}${exception:format=tostring:maxInnerExceptionLevel=10}}",
        "rowHighlightingRules": [
          {
            "condition": "level == LogLevel.Trace",
            "foregroundColor": "Gray"
          },
          {
            "condition": "level == LogLevel.Info",
            "foregroundColor": "Green"
          },
          {
            "condition": "level == LogLevel.Warning",
            "foregroundColor": "Yellow"
          },
          {
            "condition": "level == LogLevel.Error",
            "foregroundColor": "Red"
          },
          {
            "condition": "level == LogLevel.Fatal",
            "foregroundColor": "Red",
            "backgroundColor": "White"
          }
        ]
      }
    },
    "rules": [
      {
        "logger": "System.*",
        "finalMinLevel": "Warn"
      },
      {
        "logger": "Microsoft.*",
        "finalMinLevel": "Warn"
      },
      {
        "logger": "*",
        "minLevel": "Trace",
        "writeTo": "console"
      }
    ]
  }
}